# Riot API dev key: https://developer.riotgames.com (expires every 24h)
# Henrik API key: https://api.henrikdev.xyz/dashboard/ 

RIOT_API_KEY=RGAPI-your-key-here
HENRIK_API_KEY=HDEV-your-key-here

# Supabase - get from your project settings at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin bypass password — server-only, never NEXT_PUBLIC_
# Generate with: openssl rand -hex 32
ADMIN_PASSWORD=replace_with_long_random_unguessable_string
